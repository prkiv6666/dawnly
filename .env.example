# ─────────────────────────────────────────────────────────────
# Dawnly — Shopify Storefront API configuration
# Copy this file to `.env.local` and fill in your values.
# If these are left blank, the site runs on built-in demo data.
# ─────────────────────────────────────────────────────────────

# Your Shopify store domain, e.g. dawnly-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=

# Storefront API access token (Headless / Storefront API app)
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# The product handle to feature as the one product
NEXT_PUBLIC_SHOPIFY_PRODUCT_HANDLE=dawnly

# Your public site URL (used for SEO canonical, sitemap, and OG tags).
# e.g. https://dawnly.shop — defaults to https://dawnly.shop if blank.
NEXT_PUBLIC_SITE_URL=
